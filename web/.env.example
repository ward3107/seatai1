# Environment Variables Template

# Copy this file to `.env` in the web directory and fill in your values

# ===================================================================
# API Configuration (Optional - for future backend integration)
# ===================================================================

# API URL for backend services (leave empty for client-side only mode)
VITE_API_URL=

# Analytics (Optional)
VITE_ANALYTICS_ID=

# Error Tracking (Optional)
VITE_SENTRY_DSN=

# ===================================================================
# Google Classroom roster import (Optional)
# ===================================================================

# OAuth 2.0 Web client ID from a Google Cloud project with the Classroom
# API enabled and scopes classroom.courses.readonly + classroom.rosters.readonly.
# When set, teachers can import a class roster directly from Google Classroom.
# The flow is 100% client-side (Google Identity Services implicit token) — no
# student data passes through any SeatAI server. Leave empty to hide the feature.
VITE_GOOGLE_CLIENT_ID=

# ===================================================================
# LTI 1.3 roster sync (Optional — requires the Vercel serverless functions)
# ===================================================================

# JSON array of trusted LMS platforms that may launch SeatAI. Each entry:
# { "issuer": "...", "clientId": "...", "authEndpoint": "...",
#   "tokenEndpoint": "...", "jwksUri": "...", "deploymentId": "..." }
LTI_PLATFORMS=

# The tool's RSA private key (PKCS8 PEM). Used to sign client assertions and
# the OIDC state. The matching public key is served at /api/lti/jwks.
# Generate: openssl genpkey -algorithm RSA -pkcs8 -out key.pem -pkeyopt rsa_keygen_bits:2048
# Paste with literal \n between lines, or as a multiline value if your host allows.
LTI_PRIVATE_KEY=

# Key id advertised in the JWKS (any stable string).
LTI_KID=seatai-lti

# Public base URL of the deployed tool (e.g. https://seatai.example.com).
# Optional — inferred from the request host when unset.
LTI_TOOL_URL=

# ===================================================================
# Feature Flags
# ===================================================================

# Enable debug mode (shows extra logging)
VITE_DEBUG=false

# ===================================================================
# Development Settings
# ===================================================================

# Development server port (default: 5173)
# VITE_PORT=5173

# ===================================================================
# Build Settings
# ===================================================================

# Base URL for deployment (default: /)
# VITE_BASE_URL=/

# ===================================================================
# Notes
# ===================================================================

# - Leave values empty if not needed
# - Never commit .env file with real secrets to git
# - Use .env.local for local overrides (not committed)
# - See .env.example for reference
