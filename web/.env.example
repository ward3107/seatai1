# Environment Variables Template

# Copy this file to `.env` in the web directory and fill in your values

# ===================================================================
# API Configuration (Optional - for future backend integration)
# ===================================================================

# API URL for backend services (leave empty for client-side only mode)
VITE_API_URL=

# Analytics (Optional)
VITE_ANALYTICS_ID=

# Error Tracking (Optional)
VITE_SENTRY_DSN=

# ===================================================================
# Feature Flags
# ===================================================================

# Enable debug mode (shows extra logging)
VITE_DEBUG=false

# ===================================================================
# Development Settings
# ===================================================================

# Development server port (default: 5173)
# VITE_PORT=5173

# ===================================================================
# Build Settings
# ===================================================================

# Base URL for deployment (default: /)
# VITE_BASE_URL=/

# ===================================================================
# Notes
# ===================================================================

# - Leave values empty if not needed
# - Never commit .env file with real secrets to git
# - Use .env.local for local overrides (not committed)
# - See .env.example for reference
